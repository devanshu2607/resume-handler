{
  "name": "portal-root",
  "version": "1.0.0",
  "description": "Root workspace to manage Gateway and Frontend together",
  "scripts": {
    "install:gateway": "npm install --prefix gateway",
    "install:frontend": "npm install --prefix frontend",
    "install:all": "npm run install:gateway && npm run install:frontend",
    "start:gateway": "npm start --prefix gateway",
    "start:frontend": "npm run dev --prefix frontend",
    "test:gateway": "npm test --prefix gateway",
    "test:frontend": "npm run test --prefix frontend"
  }
}
